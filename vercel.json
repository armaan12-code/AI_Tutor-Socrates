{
  "rewrites": [
    {
      "source": "/api/tutor/stream",
      "destination": "/api/tutor"
    },
    {
      "source": "/api/tutor",
      "destination": "/api/tutor"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}